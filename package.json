{
  "name": "mf-base",
  "version": "2.0.0-SNAPSHOT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build_prod_aot": "ng build --configuration production --aot --build-optimizer=true --vendor-chunk=true --common-chunk=true --extract-licenses --optimization=true",
    "build_pre_aot": "ng build --configuration pre --aot --build-optimizer=true --vendor-chunk=true --common-chunk=true --extract-licenses --optimization=true",
    "build_sqm_aot": "ng build --configuration sqm --aot --build-optimizer=true --vendor-chunk=true --common-chunk=true --extract-licenses --optimization=true",
    "build_dev_aot": "ng build --configuration dev  --aot --build-optimizer=true --vendor-chunk=true --common-chunk=true --extract-licenses --optimization=true",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "run:all": "node node_modules/@angular-architects/module-federation/src/server/mf-dev-server.js"
  },
  "private": true,
  "dependencies": {
    "@angular-architects/module-federation": "^17.0.1",
    "@angular/animations": "^17.0.0",
    "@angular/cdk": "^17.0.3",
    "@angular/common": "^17.0.0",
    "@angular/compiler": "^17.0.0",
    "@angular/core": "^17.0.6",
    "@angular/flex-layout": "^15.0.0-beta.42",
    "@angular/forms": "^17.0.0",
    "@angular/material": "^17.0.3",
    "@angular/platform-browser": "^17.0.0",
    "@angular/platform-browser-dynamic": "^17.0.0",
    "@angular/router": "^17.0.0",
    "@material/tooltip": "^15.0.0-canary.a246a4439.0",
    "ngx-toastr": "^18.0.0",
    "ngx-unsubscribe": "^0.0.1",
    "rxjs": "~7.8.0",
    "sweetalert2": "^11.10.5",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.0.6",
    "@angular/cli": "^17.0.6",
    "@angular/compiler-cli": "^17.0.0",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ngx-build-plus": "^17.0.0",
    "typescript": "~5.2.2"
  }
}
