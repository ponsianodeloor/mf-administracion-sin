{
	"$schema": "./node_modules/@angular/cli/lib/config/schema.json",
	"version": 1,
	"newProjectRoot": "projects",
	"projects": {
		"mf-ubicacion": {
			"projectType": "application",
			"schematics": {
				"@schematics/angular:component": {
					"style": "scss"
				}
			},
			"root": "projects/mf-ubicacion",
			"sourceRoot": "projects/mf-ubicacion/src",
			"prefix": "app",
			"architect": {
				"build": {
					"builder": "ngx-build-plus:browser",
					"options": {
						"outputPath": "dist/mf-ubicacion",
						"index": "projects/mf-ubicacion/src/index.html",
						"polyfills": [
							"zone.js"
						],
						"tsConfig": "projects/mf-ubicacion/tsconfig.app.json",
						"inlineStyleLanguage": "scss",
						"assets": [
							"projects/mf-ubicacion/src/favicon.ico",
							"projects/mf-ubicacion/src/assets"
						],
						"styles": [
							"projects/mf-ubicacion/src/styles.scss"
						],
						"scripts": [],
						"main": "projects/mf-ubicacion/src/main.ts",
						"extraWebpackConfig": "projects/mf-ubicacion/webpack.config.js",
						"commonChunk": false
					},
					"configurations": {
						"production": {
							"budgets": [
								{
									"type": "initial",
									"maximumWarning": "500kb",
									"maximumError": "1mb"
								},
								{
									"type": "anyComponentStyle",
									"maximumWarning": "2kb",
									"maximumError": "4kb"
								}
							],
							"outputHashing": "all",
							"extraWebpackConfig": "projects/mf-ubicacion/webpack.prod.config.js"
						},
						"development": {
							"optimization": false,
							"extractLicenses": false,
							"sourceMap": true
						}
					},
					"defaultConfiguration": "production"
				},
				"serve": {
					"builder": "ngx-build-plus:dev-server",
					"configurations": {
						"production": {
							"buildTarget": "mf-ubicacion:build:production",
							"extraWebpackConfig": "projects/mf-ubicacion/webpack.prod.config.js"
						},
						"development": {
							"buildTarget": "mf-ubicacion:build:development"
						}
					},
					"defaultConfiguration": "development",
					"options": {
						"port": 4203,
						"publicHost": "http://localhost:4203",
						"extraWebpackConfig": "projects/mf-ubicacion/webpack.config.js"
					}
				},
				"extract-i18n": {
					"builder": "ngx-build-plus:extract-i18n",
					"options": {
						"buildTarget": "mf-ubicacion:build",
						"extraWebpackConfig": "projects/mf-ubicacion/webpack.config.js"
					}
				},
				"test": {
					"builder": "@angular-devkit/build-angular:karma",
					"options": {
						"polyfills": [
							"zone.js",
							"zone.js/testing"
						],
						"tsConfig": "projects/mf-ubicacion/tsconfig.spec.json",
						"inlineStyleLanguage": "scss",
						"assets": [
							"projects/mf-ubicacion/src/favicon.ico",
							"projects/mf-ubicacion/src/assets"
						],
						"styles": [
							"projects/mf-ubicacion/src/styles.scss"
						],
						"scripts": []
					}
				}
			}
		},
